<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Connection Management</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: system-ui, sans-serif; background: #f3f3f3; padding: 20px; }
.wrap { padding: 1rem 0; }
.header-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; }
.page-title { font-size: 22px; font-weight: 500; color: #111; display: flex; align-items: center; gap: 10px; }
.count { font-size: 13px; color: #666; margin-bottom: 10px; }
.controls { display: flex; align-items: center; gap: 8px; }
.search-box { position: relative; }
.search-box input { padding: 6px 10px 6px 30px; font-size: 13px; border-radius: 8px; border: 0.5px solid #ccc; background: #fff; color: #111; width: 200px; }
.search-icon { position: absolute; left: 9px; top: 50%; transform: translateY(-50%); color: #999; font-size: 14px; }
.btn-new { padding: 6px 14px; font-size: 13px; font-weight: 500; border-radius: 8px; border: 1.5px solid #1589ee; color: #1589ee; background: transparent; cursor: pointer; white-space: nowrap; }
.btn-new:hover { background: #e6f1fb; }
table { width: 100%; border-collapse: collapse; font-size: 13px; table-layout: fixed; }
thead th { padding: 8px 12px; text-align: left; font-weight: 500; color: #666; border-bottom: 1px solid #e0e0e0; cursor: pointer; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; user-select: none; background: #f8f8f8; }
thead th:hover { color: #111; }
thead th .sort-icon { margin-left: 4px; opacity: 0.5; font-size: 11px; }
thead th.sorted .sort-icon { opacity: 1; color: #1589ee; }
tbody tr { border-bottom: 0.5px solid #e8e8e8; }
tbody tr:hover { background: #f5f5f5; }
tbody td { padding: 9px 12px; color: #111; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.col-num { width: 36px; color: #888; font-size: 12px; }
.col-name { width: 140px; font-weight: 500; }
.col-source { width: 130px; }
.col-pipeline { width: 155px; }
.col-namedcred { width: 130px; }
.col-status { width: 105px; }
.col-expiry { width: 105px; }
.col-modified { width: 120px; }
.col-action { width: 36px; }
a.pipeline-link { color: #1589ee; text-decoration: none; }
a.pipeline-link:hover { text-decoration: underline; }
.status-badge { display: inline-flex; align-items: center; gap: 5px; font-size: 12px; font-weight: 500; }
.dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; flex-shrink: 0; }
.dot-active { background: #2e7d32; }
.dot-expired { background: #e65100; }
.status-active { color: #2e7d32; }
.status-expired { color: #e65100; }
.expiry-ok { color: #111; font-weight: 500; }
.expiry-warn { color: #b45309; font-weight: 500; }
.expiry-critical { color: #c0392b; font-weight: 600; }
.expiry-expired { color: #c0392b; font-weight: 600; font-style: italic; }
.expiry-none { color: #aaa; font-size: 12px; }
.warn-icon { font-size: 14px; }
.cred-pill { display: inline-block; font-size: 11px; padding: 2px 8px; border-radius: 20px; background: #e6f1fb; color: #185fa5; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 120px; }
.action-btn { background: none; border: none; cursor: pointer; color: #888; font-size: 16px; padding: 2px 6px; border-radius: 8px; }
.action-btn:hover { background: #f0f0f0; color: #111; }
.filters { display: flex; gap: 8px; margin-bottom: 10px; flex-wrap: wrap; align-items: center; }
.filter-label { font-size: 12px; color: #666; }
.filter-btn { font-size: 12px; padding: 4px 12px; border-radius: 20px; border: 0.5px solid #ccc; background: transparent; color: #666; cursor: pointer; }
.filter-btn.active { background: #1589ee; color: #fff; border-color: #1589ee; }
.filter-btn:hover:not(.active) { background: #f0f0f0; }
.legend { display: flex; gap: 16px; font-size: 11px; color: #888; margin-bottom: 8px; align-items: center; flex-wrap: wrap; }
.legend-item { display: flex; align-items: center; gap: 5px; }
.legend-dot { width: 8px; height: 8px; border-radius: 50%; }
</style>
</head>
<body>

<div class="wrap">
  <div class="header-row">
    <div class="page-title">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <circle cx="12" cy="12" r="3"/>
        <path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12"/>
      </svg>
      Connection Management
    </div>
    <div class="controls">
      <div class="search-box">
        <span class="search-icon">&#128269;</span>
        <input type="text" id="searchInput" placeholder="Search..." oninput="renderTable()" />
      </div>
      <button class="btn-new">+ New Connection</button>
    </div>
  </div>

  <div class="filters">
    <span class="filter-label">Filter:</span>
    <button class="filter-btn active" onclick="setFilter('all', this)">All</button>
    <button class="filter-btn" onclick="setFilter('active', this)">Active</button>
    <button class="filter-btn" onclick="setFilter('expired', this)">Expired</button>
    <button class="filter-btn" onclick="setFilter('expiring', this)">Expiring soon</button>
  </div>

  <div class="legend">
    <span class="legend-item"><span class="legend-dot" style="background:#2e7d32"></span>Active</span>
    <span class="legend-item"><span class="legend-dot" style="background:#e65100"></span>Expired</span>
    <span class="legend-item" style="color:#b45309">&#9888; Expiring &lt;30 days</span>
    <span class="legend-item" style="color:#c0392b">&#10006; Expiring &lt;7 days / expired</span>
  </div>

  <div class="count" id="rowCount">13 items</div>

  <div style="overflow-x:auto;">
    <table id="connTable">
      <thead>
        <tr>
          <th class="col-num">#</th>
          <th class="col-name sorted" onclick="sortBy('name')">Connection Name <span class="sort-icon">&#8593;</span></th>
          <th class="col-source" onclick="sortBy('source')">Source <span class="sort-icon">&#8597;</span></th>
          <th class="col-pipeline" onclick="sortBy('pipeline')">Pipeline Name <span class="sort-icon">&#8597;</span></th>
          <th class="col-namedcred" onclick="sortBy('namedCred')">Named Credential <span class="sort-icon">&#8597;</span></th>
          <th class="col-status" onclick="sortBy('status')">Connection Status <span class="sort-icon">&#8597;</span></th>
          <th class="col-expiry" onclick="sortBy('expiry')">Token Expiry <span class="sort-icon">&#8597;</span></th>
          <th class="col-modified" onclick="sortBy('modified')">Last Modified <span class="sort-icon">&#8597;</span></th>
          <th class="col-action"></th>
        </tr>
      </thead>
      <tbody id="tableBody"></tbody>
    </table>
  </div>
</div>

<script>
const data = [
  { name: "abc1", source: "Taboola for MI", pipeline: "abc1 1749106047", pipelineLink: true, namedCred: "Taboola_OAuth_Prod", status: "Active", expiryDays: 87, modified: "4/7/2026, 07:01 AM" },
  { name: "con1", source: "MI Mock", pipeline: "", pipelineLink: false, namedCred: "MIMock_ServiceAcct_1", status: "Active", expiryDays: 210, modified: "3/2/2026, 04:45 AM" },
  { name: "con2", source: "MI Mock", pipeline: "", pipelineLink: false, namedCred: "MIMock_ServiceAcct_2", status: "Active", expiryDays: 198, modified: "3/2/2026, 04:45 AM" },
  { name: "con3", source: "MI Mock", pipeline: "", pipelineLink: false, namedCred: "MIMock_ServiceAcct_3", status: "Active", expiryDays: 165, modified: "3/2/2026, 04:46 AM" },
  { name: "conn5", source: "MI Mock", pipeline: "conn5 1281563918", pipelineLink: true, namedCred: "MIMock_ServiceAcct_5", status: "Active", expiryDays: 55, modified: "3/3/2026, 04:11 AM" },
  { name: "conn6", source: "MI Mock", pipeline: "conn6 864847048", pipelineLink: true, namedCred: "MIMock_ServiceAcct_6", status: "Active", expiryDays: 44, modified: "3/3/2026, 04:11 AM" },
  { name: "GA4", source: "Google Analytics For EMI", pipeline: "GA4 667312831", pipelineLink: true, namedCred: "GoogleOAuth_Analytics_Prod", status: "Active", expiryDays: 12, modified: "4/28/2026, 11:58 PM" },
  { name: "GoogleMock", source: "MI Mock", pipeline: "", pipelineLink: false, namedCred: "Google_MockCred_Dev", status: "Active", expiryDays: 99, modified: "3/18/2026, 07:54 AM" },
  { name: "kjl", source: "LinkedIn Ads For EMI", pipeline: "kjl 671186990", pipelineLink: true, namedCred: "LinkedIn_OAuth_kjl", status: "Expired", expiryDays: -3, modified: "4/29/2026, 12:02 AM" },
  { name: "lklklk", source: "Taboola for MI", pipeline: "lklklk 1728853758", pipelineLink: true, namedCred: "Taboola_OAuth_Dev", status: "Active", expiryDays: 210, modified: "4/7/2026, 01:08 AM" },
  { name: "lklklklklkl2112", source: "LinkedIn Ads For EMI", pipeline: "lklklklklkl2112 1200553268", pipelineLink: true, namedCred: "LinkedIn_OAuth_lklklk", status: "Expired", expiryDays: -10, modified: "4/19/2026, 12:03 AM" },
  { name: "new linkedin", source: "LinkedIn Ads For EMI", pipeline: "new_linkedin 1289556458", pipelineLink: true, namedCred: "LinkedIn_OAuth_NewConn", status: "Expired", expiryDays: -1, modified: "4/29/2026, 12:03 AM" },
  { name: "samir_conn1", source: "Meta Ads", pipeline: "samir_conn1 1200920001", pipelineLink: false, namedCred: "MetaAds_OAuth_Samir", status: "Active", expiryDays: 44, modified: "3/3/2026, 01:52 AM" },
];

let sortKey = 'name';
let sortDir = 1;
let filterMode = 'all';

function setFilter(mode, btn) {
  filterMode = mode;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderTable();
}

function sortBy(key) {
  if (sortKey === key) sortDir *= -1;
  else { sortKey = key; sortDir = 1; }
  renderTable();
}

function expiryClass(days, status) {
  if (status === 'Expired' || days < 0) return 'expiry-expired';
  if (days <= 7) return 'expiry-critical';
  if (days <= 30) return 'expiry-warn';
  return 'expiry-ok';
}

function expiryText(days, status) {
  if (status === 'Expired' || days < 0) return 'Expired';
  return days + ' days';
}

function expiryIcon(days, status) {
  if (status === 'Expired' || days < 0) return '<span class="warn-icon" style="color:#c0392b">&#10006; </span>';
  if (days <= 30) return '<span class="warn-icon" style="color:#b45309">&#9888; </span>';
  return '';
}

function renderTable() {
  const q = document.getElementById('searchInput').value.toLowerCase();
  let rows = data.filter(r => {
    const match = !q || r.name.toLowerCase().includes(q) || r.source.toLowerCase().includes(q) || r.pipeline.toLowerCase().includes(q) || r.namedCred.toLowerCase().includes(q);
    if (!match) return false;
    if (filterMode === 'active') return r.status === 'Active' && r.expiryDays > 30;
    if (filterMode === 'expired') return r.status === 'Expired' || r.expiryDays < 0;
    if (filterMode === 'expiring') return r.status === 'Active' && r.expiryDays >= 0 && r.expiryDays <= 30;
    return true;
  });

  rows.sort((a, b) => {
    let av = a[sortKey], bv = b[sortKey];
    if (sortKey === 'expiry') { av = a.expiryDays; bv = b.expiryDays; }
    if (typeof av === 'string') return av.localeCompare(bv) * sortDir;
    return (av - bv) * sortDir;
  });

  document.getElementById('rowCount').textContent = rows.length + ' item' + (rows.length !== 1 ? 's' : '');

  const tbody = document.getElementById('tableBody');
  tbody.innerHTML = rows.map((r, i) => {
    const eClass = expiryClass(r.expiryDays, r.status);
    const eText = expiryText(r.expiryDays, r.status);
    const eIcon = expiryIcon(r.expiryDays, r.status);
    const statusDot = r.status === 'Active' ? 'dot-active' : 'dot-expired';
    const statusClass = r.status === 'Active' ? 'status-active' : 'status-expired';
    const pipeline = r.pipelineLink
      ? `<a class="pipeline-link" href="#">${r.pipeline}</a>`
      : `<span style="color:#aaa;font-size:12px">—</span>`;
    return `<tr>
      <td class="col-num">${i + 1}</td>
      <td class="col-name" title="${r.name}">${r.name}</td>
      <td class="col-source" title="${r.source}">${r.source}</td>
      <td class="col-pipeline" title="${r.pipeline}">${r.pipeline ? pipeline : '<span style="color:#aaa;font-size:12px">—</span>'}</td>
      <td class="col-namedcred" title="${r.namedCred}"><span class="cred-pill">${r.namedCred}</span></td>
      <td class="col-status"><span class="status-badge"><span class="dot ${statusDot}"></span><span class="${statusClass}">${r.status}</span></span></td>
      <td class="col-expiry"><span class="${eClass}">${eIcon}${eText}</span></td>
      <td class="col-modified" style="font-size:12px;color:#888">${r.modified}</td>
      <td class="col-action"><button class="action-btn" title="Actions">&#8964;</button></td>
    </tr>`;
  }).join('');
}

renderTable();
</script>

</body>
</html>
